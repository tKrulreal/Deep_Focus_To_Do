<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Statistics"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvTotalFocusMinutes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="#EFEFEF"
            android:padding="16dp"
            android:text="Tổng phút tập trung: 0"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvCompletedSessions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#EFEFEF"
            android:padding="16dp"
            android:text="Tổng phiên hoàn thành: 0"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvTotalPoints"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#EFEFEF"
            android:padding="16dp"
            android:text="Tổng điểm: 0"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvStreak"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#EFEFEF"
            android:padding="16dp"
            android:text="Streak: 0 ngày"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvTodayUsage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#EFEFEF"
            android:padding="16dp"
            android:text="Thời gian dùng app khác hôm nay: 0 phút"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvBlockedAttempts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#EFEFEF"
            android:padding="16dp"
            android:text="Số lần mở app bị chặn: 0"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/tvDailyChart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="#EFEFEF"
            android:fontFamily="monospace"
            android:padding="16dp"
            android:text="Biểu đồ 7 ngày"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>
<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.DeepFocus.PageTitle" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="TextAppearance.DeepFocus.PageSubtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="Widget.DeepFocus.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">22dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">?attr/colorSurfaceContainerLow</item>
    </style>


    <style name="Widget.DeepFocus.Button.Primary" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.DeepFocus.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">16dp</item>
    </style>
</resources>


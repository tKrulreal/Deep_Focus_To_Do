<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thiết lập chặn ứng dụng"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnBackground"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ứng dụng cần một vài quyền để có thể chặn app gây xao nhãng."
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:textColor="?attr/colorOnBackground"/>

        <!-- ===== 2 STEP NGANG ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">

            <!-- STEP 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginEnd="8dp">

                <TextView
                    android:text="Bước 1"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Cấp quyền truy cập sử dụng"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvUsageStatus"
                    android:text="Trạng thái: Chưa cấp"
                    android:textColor="#F44336"
                    android:textStyle="italic"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/btnUsagePermission"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chỉnh quyền"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>

            <!-- STEP 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:elevation="2dp"
                android:padding="16dp"
                android:layout_marginStart="8dp">

                <TextView
                    android:text="Bước 2"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Cho phép hiển thị trên ứng dụng khác"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvOverlayStatus"
                    android:text="Trạng thái: Chưa cấp"
                    android:textColor="#F44336"
                    android:textStyle="italic"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <Button
                    android:id="@+id/btnOverlayPermission"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chỉnh quyền"
                    android:layout_marginTop="12dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- CONTINUE BUTTON -->
        <Button
            android:id="@+id/btnBlockApp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tiếp tục chọn ứng dụng để chặn"
            android:layout_marginTop="28dp"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"/>

    </LinearLayout>

</ScrollView>